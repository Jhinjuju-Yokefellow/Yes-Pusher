{
  "name": "yes-pusher-shared-world",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "dev:server": "node --import ./apps/world-server/normalize-sdk-base-url.js --import ./apps/world-server/personal-result-patch.js --import ./apps/world-server/settlement-recovery-patch.js --import ./apps/world-server/direct-offering-resolution-patch.js --import ./apps/world-server/skin-loadout-patch.js --import ./apps/world-server/rubber-duck-toy-patch.js --import ./src/game/replay-physics.js apps/world-server/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node --import ./apps/world-server/normalize-sdk-base-url.js --import ./apps/world-server/personal-result-patch.js --import ./apps/world-server/settlement-recovery-patch.js --import ./apps/world-server/direct-offering-resolution-patch.js --import ./apps/world-server/skin-loadout-patch.js --import ./apps/world-server/rubber-duck-toy-patch.js --import ./src/game/replay-physics.js apps/world-server/server.js",
    "test": "node --test"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.165.0",
    "viem": "^2.55.0"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  }
}
