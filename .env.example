# Browser build. On Vercel, point this at the public Railway world server.
# Leave blank for same-origin/local development.
VITE_WORLD_SERVER_URL=

# World server access. Use exact Vercel origins in hosted testing.
# Multiple origins are comma-separated. Empty allows any origin for local development.
YES_PUSHER_ALLOWED_ORIGINS=
YES_PUSHER_REQUIRE_WALLET=true
YES_PUSHER_TEST_MODE=false

# Persistent authoritative-world files. Mount a Railway volume at /data.
YES_PUSHER_DATA_DIR=.world-data

# Shared-world orchestration and recorded replay.
YES_PUSHER_TICK_RATE=45
YES_PUSHER_BROADCAST_RATE=2
# Railway preparation is capped at 10 fps; browsers interpolate the full replay smoothly.
YES_PUSHER_REPLAY_FRAME_RATE=10

# Maximum number of unclaimed physical toys allowed in the shared machine.
YES_PUSHER_MAX_TOYS=8
# One-time migration: clears only confirmed-world.json and active-replay.json, preserving player/reward/loadout data.
YES_PUSHER_ONE_TIME_MACHINE_RESET=true
# Seeds one duck just behind the payout edge once, then writes a completion marker under YES_PUSHER_DATA_DIR.
YES_PUSHER_FRONT_EDGE_DEMO_DUCK=true

# Yokefellow testnet integration. Keep the app key on Railway only.
YF_API_BASE_URL=http://localhost:3000/api/sdk/v1
YF_APP_KEY=
YF_BUCKET_ID=bucket_78de9370-1f1d-4075-8145-1fba4d76b48b
YES_PUSHER_APP_SLUG=yes-pusher
YES_PUSHER_SKIN_DROP_TRIGGER_KEY=coin_pusher.random_skin_drop
YES_PUSHER_SKIN_DROP_OFFERING_NAME=Random Coin Skin Drop

YES_PUSHER_YES_PER_COIN_RAW=1000000000000000000
YF_CREDIT_GRANT_URL=
